    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI (uvicorn, 8077)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "masc_ahu_dwg2excel_api.api:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8077",
                "--reload",
                "--log-level",
                "debug"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "ODAFC_EXEC_PATH": "C:\\Program Files\\ODA\\ODAFileConverter 27.1.0\\ODAFileConverter.exe"
            }
        }
    ]
}